# Environment Configuration for CodeLens Backend
# Copy this to .env and adjust values

# Path to the local VectorAI DB directory
VECTORAI_DB_PATH=./.vectorai_db

# Ollama server address (default: local)
OLLAMA_HOST=http://localhost:11434

# Embedding model (nomic-embed-text gives 768-dim vectors, ~274MB)
EMBED_MODEL=nomic-embed-text

# Max tokens per chunk (safety cap)
CHUNK_SIZE=512

# Number of results to return per query
TOP_K=10
